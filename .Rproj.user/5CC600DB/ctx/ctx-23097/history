adae_data %>% count(USUBJID)
n_total <- nrow(adae_data)
ae_vars_ci <- adae_data %>%
group_by(AETERM) %>%
summarise(
events = n(),  # simply count rows for that AE
.groups = "drop"
) %>%
mutate(
n = n_total,
incidence = events / n,
se = sqrt(incidence * (1 - incidence) / n),
lower = pmax(0, incidence - 1.96 * se),
upper = pmin(1, incidence + 1.96 * se)
)
View(ae_vars_ci)
View(ae_vars_ci)
ggplot(ae_vars_ci, aes(x = incidence, y = AETERM)) +
geom_point(size = 3) +
geom_errorbar(aes(ymin = lower, ymax = upper), width = 0.2)
